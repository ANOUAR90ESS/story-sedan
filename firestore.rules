rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isServerTimestamp(field) {
      return incoming()[field] == request.time;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['createdAt']) &&
             data.keys().size() <= 3 && // displayName, photoURL
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100) &&
             (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 500);
    }

    function isValidIdea(data) {
      return data.keys().hasAll(['title', 'userId', 'createdAt', 'structure', 'metadata']) &&
             data.title is string && data.title.size() <= 200 &&
             data.userId == request.auth.uid &&
             data.structure is map &&
             data.metadata is map &&
             (data.get('fullScript', '') is string && data.get('fullScript', '').size() <= 60000) &&
             (data.get('visualStyle', '') is string && data.get('visualStyle', '').size() <= 2000) &&
             (data.get('rareAngle', '') is string && data.get('rareAngle', '').size() <= 2000) &&
             (data.get('scenes', []).size() <= 100);
    }

    // --- Rules ---

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming()) && isServerTimestamp('createdAt');
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().createdAt == existing().createdAt;
    }

    // Historical Ideas
    match /ideas/{ideaId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(ideaId) && isValidIdea(incoming()) && 
                    isServerTimestamp('createdAt');
      
      allow update: if isSignedIn() && isOwner(existing().userId) &&
                    incoming().userId == existing().userId &&
                    // Ensure the update doesn't touch the creation timestamp
                    incoming().get('createdAt', existing().createdAt) == existing().createdAt &&
                    (incoming().get('updatedAt', null) == null || isServerTimestamp('updatedAt')) &&
                    // Action: Update Progress or Details
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'hook', 'rareAngle', 'fullScript', 'scenes', 'structure', 'metadata', 'updatedAt', 'visualStyle', 'id', 'visuals', 'historicalFacts']);
                    
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
